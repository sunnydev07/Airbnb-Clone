<div class="edit-container">
    <div class="edit-card">
        <div class="edit-header">
            <h2><i class="fa-solid fa-pen-to-square"></i> Edit Listing</h2>
            <p class="edit-subtitle">Update your space details</p>
        </div>
        
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data">
            <div class="form-group">
                <label>Title</label>
                <input name="listing[title]" value="<%= listing.title %>" type="text" placeholder="Beautiful home in the mountains" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="listing[description]" rows="4" placeholder="Describe your special place..." required><%= listing.description %></textarea>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Location</label>
                    <input name="listing[location]" value="<%= listing.location %>" type="text" placeholder="City, State" required>
                </div>
                <div class="form-group half">
                    <label>Country</label>
                    <input name="listing[country]" value="<%= listing.country %>" type="text" placeholder="Country" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Price per night</label>
                    <div class="price-input">
                        <span class="currency">$</span>
                        <input name="listing[price]" value="<%= listing.price %>" type="number" placeholder="0" required>
                    </div>
                </div>
                <div class="form-group half">
                    <label>Image URL</label>
                    <input name="listing[image][url]" value="<%= listing.image.url %>" type="text" placeholder="https://...">
                </div>
            </div>
            <div class="mb-3 form-group">
                <h6>Original Image</h6>
                <img src="<%= originalImage %>" style="height: 35vh; width: 30vw;"/>
            </div>
            <div class="form-group">
                <label>Upload New Image</label>
                <div class="file-upload">
                    <input name="image" type="file" accept="image/*" id="file-input">
                    <label for="file-input" class="file-label">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <span>Choose a file or drag here</span>
                    </label>
                </div>
            </div>

            <div class="form-actions">
                <a href="/listings/<%= listing._id %>" class="btn-cancel">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-check"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .edit-container {
        min-height: calc(var(--vh, 1vh) * 100);
        background: linear-gradient(135deg, #fdf2f8 0%, #fce7f3 50%, #f5f3ff 100%);
        padding: 3rem 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        padding: 2.5rem;
        width: 100%;
        max-width: 540px;
        animation: slideUp 0.4s ease-out;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .edit-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .edit-header h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .edit-header h2 i {
        color: #ff385c;
        margin-right: 0.5rem;
    }

    .edit-subtitle {
        color: #717171;
        font-size: 0.95rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #222;
        margin-bottom: 0.5rem;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background: #fafafa;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #ff385c;
        background: white;
        box-shadow: 0 0 0 4px rgba(255, 56, 92, 0.1);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 100px;
    }

    .form-row {
        display: flex;
        gap: 1rem;
    }

    .form-row .half {
        flex: 1;
    }

    .price-input {
        position: relative;
    }

    .price-input .currency {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #717171;
        font-weight: 600;
    }

    .price-input input {
        padding-left: 2rem;
    }

    .file-upload {
        position: relative;
    }

    .file-upload input[type="file"] {
        position: absolute;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .file-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.5rem;
        border: 2px dashed #ddd;
        border-radius: 12px;
        background: #fafafa;
        color: #717171;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .file-label:hover {
        border-color: #ff385c;
        background: #fff5f7;
        color: #ff385c;
    }

    .file-label i {
        font-size: 1.5rem;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-cancel {
        flex: 1;
        padding: 1rem;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        background: white;
        color: #717171;
        text-decoration: none;
        text-align: center;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover {
        border-color: #717171;
        color: #222;
    }

    .btn-save {
        flex: 2;
        padding: 1rem;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #ff385c 0%, #e31e5f 100%);
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 56, 92, 0.3);
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 56, 92, 0.4);
    }

    .btn-save:active {
        transform: translateY(0);
    }

    @media (max-width: 780px) {
        .edit-container {
            padding: 2rem 1rem;
        }

        .edit-card {
            max-width: 100%;
        }

        .file-label {
            flex-direction: column;
            text-align: center;
        }
    }

    @media (max-width: 540px) {
        .edit-card {
            padding: 1.5rem;
            border-radius: 16px;
        }

        .form-row {
            flex-direction: column;
            gap: 0;
        }

        .form-actions {
            flex-direction: column-reverse;
        }
    }
</style>
