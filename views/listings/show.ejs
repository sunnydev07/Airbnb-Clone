<div class="listing-show-container mx-auto my-4">
    <div class="listing-show-header mb-3">
        <h1 class="listing-title"><%= listing.title %></h1>
        <div class="text-muted fs-6 d-flex align-items-center gap-2">
            <i class="fa-solid fa-location-dot"></i>
            <span><%= listing.location %>, <%= listing.country %></span>
        </div>
    </div>

    <div class="listing-hero mb-4">
        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-hero-img" />
    </div>

    <div class="row g-5">
        <div class="col-lg-8">
            <div class="host-badge mb-4">
                <div class="host-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <div>
                    <div class="host-name">Hosted by <%= listing.owner && listing.owner.username ? listing.owner.username : 'Unknown host' %></div>
                    <div class="text-muted small">Superhost &middot; 4 years hosting</div>
                </div>
            </div>
            
            <hr class="my-4">

            <div class="listing-desc mb-4">
                <h4 class="section-title">About this space</h4>
                <p class="text-secondary mt-3" style="line-height:1.75;"><%= listing.description %></p>
            </div>

            <hr class="my-4">

            <div class="map-section mb-4">
                <h4 class="section-title">Where you'll be</h4>
                <p class="text-muted mb-3"><i class="fa-solid fa-location-arrow"></i> <%= listing.location %>, <%= listing.country %></p>
                <div class="map-container shadcn-card p-0">
                    <div id="map"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="shadcn-card sticky-pricing-card">
                <div class="d-flex align-items-baseline gap-2 mb-4">
                    <span class="price-display">&#8377;<%= listing.price != null ? listing.price.toLocaleString('en-IN') : 'N/A' %></span>
                    <span class="text-muted">/ night</span>
                </div>

                <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                    <div class="d-flex flex-column gap-3">
                        <form action="/listings/<%= listing._id %>/edit" method="GET" class="w-100">
                            <button class="btn-reserve w-100" style="background:#222;">Edit Listing</button>
                        </form>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="w-100">
                            <button class="btn-outline-shadcn w-100" style="border-color:var(--red); color:var(--red);">Delete Listing</button>
                        </form>
                    </div>
                <% } else { %>
                    <button class="btn-reserve mb-2">Reserve</button>
                    <div class="text-center text-muted small">You won't be charged yet</div>
                <% } %>
            </div>
        </div>
    </div>
    
    <hr class="my-5">

    <div class="reviews-section mb-5">
        <h4 class="section-title mb-4">
            <i class="fa-solid fa-star text-warning"></i> 
            <%= listing.reviews.length > 0 ? listing.reviews.length + ' Reviews' : 'No reviews yet' %>
        </h4>

        <% if(currUser) { %>
            <div class="shadcn-card mb-5">
                <h5 class="mb-3" style="font-weight:600;">Leave a Review</h5>
                <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
                    <div class="mb-3">
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <div class="mb-3">
                        <label for="comment" class="form-label text-muted">How was your experience?</label>
                        <textarea name="review[comment]" id="comment" class="form-control" rows="4" required style="border-radius:0.5rem;"></textarea>
                        <div class="invalid-feedback">Please write a little bit about your experience.</div>
                    </div>
                    <button class="btn btn-dark" style="border-radius:0.5rem; padding:0.5rem 1.5rem;">Submit Review</button>
                </form>
            </div>
        <% } else { %>
            <div class="alert alert-secondary">
                You must be <a href="/login">logged in</a> to leave a review.
            </div>
        <% } %>

        <% if(listing.reviews.length > 0) { %>
            <div class="row g-4">
                <% for (review of listing.reviews) { %>
                    <div class="col-md-6">
                        <div class="shadcn-card review-card">
                            <div class="review-header">
                                <div class="review-avatar">
                                    <%= review.author.username.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@<%= review.author.username %></h6>
                                    <div class="text-muted small">
                                        <p class="starability-result" data-rating="<%= review.rating %>" style="transform: scale(0.6); transform-origin: left; margin:0;">
                                            Rated: <%= review.rating %> stars
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <p class="text-secondary mt-2 mb-3" style="font-size:0.95rem;"><%= review.comment %></p>
                            <% if (currUser && review.author._id.equals(currUser._id)) { %>
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-outline-danger" style="border-radius: 0.5rem;">Delete</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<script>
    function initMap() {
        const address = <%- JSON.stringify(`${listing.location}, ${listing.country}`) %>;
        const listingTitle = <%- JSON.stringify(listing.title) %>;
        const listingLocation = <%- JSON.stringify(listing.location) %>;

        const storedLat = <%- JSON.stringify(mapCoordinates && mapCoordinates.latitude != null ? mapCoordinates.latitude : null) %>;
        const storedLng = <%- JSON.stringify(mapCoordinates && mapCoordinates.longitude != null ? mapCoordinates.longitude : null) %>;
        const hasStoredCoords = typeof storedLat === 'number'
            && typeof storedLng === 'number'
            && Number.isFinite(storedLat)
            && Number.isFinite(storedLng);

        // Start with stored coordinates or a temporary center
        const tempCenter = hasStoredCoords ? { lat: storedLat, lng: storedLng } : { lat: 20, lng: 0 };

        const map = new google.maps.Map(document.getElementById('map'), {
            zoom: 14,
            center: tempCenter,
            mapTypeId: 'roadmap',
            disableDefaultUI: true,
            zoomControl: true,
            fullscreenControl: true,
            styles: [
                { featureType: 'poi', stylers: [{ visibility: 'off' }] },
                { featureType: 'transit', stylers: [{ visibility: 'off' }] }
            ]
        });

        const infoWindow = new google.maps.InfoWindow({
            content: `
                <div style="padding: 10px 5px 5px; font-family: 'Plus Jakarta Sans', sans-serif;">
                    <h6 style="font-weight:700; margin-bottom: 4px; font-size:1rem;">${listingTitle}</h6>
                    <p style="margin-bottom: 0; color:#555; font-size:0.85rem;"><i class="fa-solid fa-location-dot"></i> ${listingLocation}</p>
                </div>
            `,
            maxWidth: 250
        });

        const placeMarker = (position) => {
            const marker = new google.maps.Marker({
                position,
                map,
                title: listingTitle,
                icon: 'http://maps.google.com/mapfiles/ms/icons/red-dot.png',
                animation: google.maps.Animation.DROP
            });
            marker.addListener('click', () => {
                infoWindow.open(map, marker);
            });
        };

        // Always geocode using Google Maps to get the accurate location
        const geocoder = new google.maps.Geocoder();
        geocoder.geocode({ address: address }, (results, status) => {
            if (status === 'OK' && results[0]) {
                const location = results[0].geometry.location;
                map.setCenter(location);
                map.setZoom(14);
                placeMarker(location);
            } else if (hasStoredCoords) {
                // Geocoding failed, fall back to stored coordinates
                map.setCenter(tempCenter);
                placeMarker(tempCenter);
            } else {
                // Last resort: show a message in the map area
                console.warn('Could not geocode address:', address, 'Status:', status);
                document.getElementById('map').innerHTML =
                    '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#888;font-size:1rem;">Map location unavailable for this listing</div>';
            }
        });
    }
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.GOOGLE_MAP_API_KEY %>&callback=initMap" async defer></script>
