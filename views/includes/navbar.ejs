<header class="airbnb-header sticky-top">
  <div class="airbnb-top-row">
    <a class="airbnb-brand" href="/listings" aria-label="Airbnb home">
      <i class="fa-brands fa-airbnb"></i>
      <span class="airbnb-wordmark">airbnb</span>
    </a>

    <button type="button" class="airbnb-mini-search" aria-label="Quick search">
      <span class="mini-segment"><i class="fa-solid fa-house"></i> Anywhere</span>
      <span class="mini-divider"></span>
      <span class="mini-segment">Anytime</span>
      <span class="mini-divider"></span>
      <span class="mini-segment muted">Add guests</span>
      <span class="mini-search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
    </button>

    <nav class="airbnb-center-tabs" aria-label="Primary navigation">
      <a href="/listings" class="tab-item active" aria-current="page">
        <i class="fa-solid fa-house-chimney"></i>
        <span>Homes</span>
      </a>
      <a href="/listings" class="tab-item">
        <span class="tab-badge">NEW</span>
        <i class="fa-solid fa-earth-americas"></i>
        <span>Experiences</span>
      </a>
      <a href="/listings/createNew" class="tab-item">
        <span class="tab-badge">NEW</span>
        <i class="fa-solid fa-bell-concierge"></i>
        <span>Services</span>
      </a>
    </nav>

    <div class="airbnb-right-actions">
      <a href="/listings/createNew" class="host-link">Become a host</a>
      <button class="icon-btn" type="button" aria-label="Language">
        <i class="fa-solid fa-globe"></i>
      </button>

      <details class="menu-popup-wrap">
        <summary class="icon-btn menu-summary" aria-label="Open menu">
          <i class="fa-solid fa-bars"></i>
        </summary>

        <div class="menu-popup" role="menu" aria-hidden="true" data-menu-popup>
          <% if(!currUser) { %>
            <a class="menu-popup-item" href="/login" role="menuitem">Login</a>
            <a class="menu-popup-item" href="/signup" role="menuitem">Signup</a>
          <% } else { %>
            <span class="menu-popup-user">Hi, <%= currUser.username %></span>
            <a class="menu-popup-item" href="/profile" role="menuitem">Profile</a>
            <a class="menu-popup-item" href="/listings?owner=me" role="menuitem">My Listings</a>
            <a class="menu-popup-item" href="/logout" role="menuitem">Logout</a>
          <% } %>
        </div>
      </details>
    </div>
  </div>

  <div class="airbnb-search-wrap">
    <div class="airbnb-search-pill">
      <button type="button" class="search-segment">
        <strong>Where</strong>
        <span>Search destinations</span>
      </button>
      <button type="button" class="search-segment">
        <strong>When</strong>
        <span>Add dates</span>
      </button>
      <button type="button" class="search-segment">
        <strong>Who</strong>
        <span>Add guests</span>
      </button>
      <button type="button" class="search-go" aria-label="Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </div>
  </div>
</header>
<div class="navbar-scroll-sentinel" aria-hidden="true"></div>