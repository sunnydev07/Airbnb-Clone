<header class="airbnb-header sticky-top">
  <div class="airbnb-top-row">
    <a class="airbnb-brand" href="/listings" aria-label="Airbnb home">
      <i class="fa-brands fa-airbnb"></i>
      <span class="airbnb-wordmark">airbnb</span>
    </a>

    <button type="button" class="airbnb-mini-search" aria-label="Quick search">
      <span class="mini-segment"><i class="fa-solid fa-house"></i> Anywhere</span>
      <span class="mini-divider"></span>
      <span class="mini-segment">Anytime</span>
      <span class="mini-divider"></span>
      <span class="mini-segment muted">Add guests</span>
      <span class="mini-search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
    </button>

    <nav class="airbnb-center-tabs" aria-label="Primary navigation">
      <a href="/listings" class="tab-item active" aria-current="page">
        <i class="fa-solid fa-house-chimney"></i>
        <span>Homes</span>
      </a>
      <a href="/listings" class="tab-item">
        <span class="tab-badge">NEW</span>
        <i class="fa-solid fa-earth-americas"></i>
        <span>Experiences</span>
      </a>
      <a href="/listings/createNew" class="tab-item">
        <span class="tab-badge">NEW</span>
        <i class="fa-solid fa-bell-concierge"></i>
        <span>Services</span>
      </a>
    </nav>

    <div class="airbnb-right-actions">
      <a href="/listings/createNew" class="host-link">Become a host</a>
      <button class="icon-btn" type="button" aria-label="Language">
        <i class="fa-solid fa-globe"></i>
      </button>

      <details class="menu-popup-wrap">
        <summary class="icon-btn menu-summary" aria-label="Open menu">
          <i class="fa-solid fa-bars"></i>
        </summary>

        <div class="menu-popup" role="menu" aria-hidden="true" data-menu-popup>
          <% if(!currUser) { %>
            <a class="menu-popup-item" href="/login" role="menuitem">Login</a>
            <a class="menu-popup-item" href="/signup" role="menuitem">Signup</a>
          <% } else { %>
            <span class="menu-popup-user">Hi, <%= currUser.username %></span>
            <a class="menu-popup-item" href="/profile" role="menuitem">Profile</a>
            <a class="menu-popup-item" href="/listings?owner=me" role="menuitem">My Listings</a>
            <a class="menu-popup-item" href="/logout" role="menuitem">Logout</a>
          <% } %>
        </div>
      </details>
    </div>
  </div>

  <div class="airbnb-search-wrap">
    <div class="airbnb-search-pill">

      <!-- WHERE -->
      <div class="search-segment-wrap" data-panel="where">
        <button type="button" class="search-segment" data-panel-toggle="where">
          <strong>Where</strong>
          <span class="segment-value" id="where-value">Search destinations</span>
        </button>
        <div class="search-dropdown where-dropdown" id="where-panel">
          <a href="#" class="dest-item" data-dest="Nearby">
            <span class="dest-icon"><i class="fa-solid fa-location-arrow"></i></span>
            <div><strong>Nearby</strong><span class="dest-sub">Find what's around you</span></div>
          </a>
          <div class="dest-heading">Suggested destinations</div>
          <a href="#" class="dest-item" data-dest="North Goa, Goa">
            <span class="dest-icon"><i class="fa-solid fa-umbrella-beach"></i></span>
            <div><strong>North Goa, Goa</strong><span class="dest-sub">Popular beach destination</span></div>
          </a>
          <a href="#" class="dest-item" data-dest="Udaipur, Rajasthan">
            <span class="dest-icon"><i class="fa-solid fa-landmark"></i></span>
            <div><strong>Udaipur, Rajasthan</strong><span class="dest-sub">For its stunning architecture</span></div>
          </a>
          <a href="#" class="dest-item" data-dest="Gurgaon District, Haryana">
            <span class="dest-icon"><i class="fa-solid fa-city"></i></span>
            <div><strong>Gurgaon District, Haryana</strong><span class="dest-sub">Popular with travellers near you</span></div>
          </a>
          <a href="#" class="dest-item" data-dest="New Delhi, Delhi">
            <span class="dest-icon"><i class="fa-solid fa-building-columns"></i></span>
            <div><strong>New Delhi, Delhi</strong><span class="dest-sub">For sights like India Gate</span></div>
          </a>
          <a href="#" class="dest-item" data-dest="Mumbai, Maharashtra">
            <span class="dest-icon"><i class="fa-solid fa-building"></i></span>
            <div><strong>Mumbai, Maharashtra</strong><span class="dest-sub">For its top-notch dining</span></div>
          </a>
          <a href="#" class="dest-item" data-dest="Varanasi, Uttar Pradesh">
            <span class="dest-icon"><i class="fa-solid fa-om"></i></span>
            <div><strong>Varanasi, Uttar Pradesh</strong><span class="dest-sub">A hidden gem</span></div>
          </a>
        </div>
      </div>

      <!-- WHEN -->
      <div class="search-segment-wrap" data-panel="when">
        <button type="button" class="search-segment" data-panel-toggle="when">
          <strong>When</strong>
          <span class="segment-value" id="when-value">Add dates</span>
        </button>
        <div class="search-dropdown when-dropdown" id="when-panel">
          <div class="when-layout">
            <div class="when-quick-picks">
              <button class="quick-pick" data-pick="today">
                <strong>Today</strong>
                <span class="quick-pick-sub" id="pick-today"></span>
              </button>
              <button class="quick-pick" data-pick="tomorrow">
                <strong>Tomorrow</strong>
                <span class="quick-pick-sub" id="pick-tomorrow"></span>
              </button>
              <button class="quick-pick" data-pick="weekend">
                <strong>This weekend</strong>
                <span class="quick-pick-sub" id="pick-weekend"></span>
              </button>
            </div>
            <div class="when-calendar">
              <div class="cal-header">
                <button class="cal-nav" id="cal-prev"><i class="fa-solid fa-chevron-left"></i></button>
                <span class="cal-month-year" id="cal-month-year"></span>
                <button class="cal-nav" id="cal-next"><i class="fa-solid fa-chevron-right"></i></button>
              </div>
              <div class="cal-weekdays">
                <span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span>
              </div>
              <div class="cal-days" id="cal-days"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- WHO -->
      <div class="search-segment-wrap" data-panel="who">
        <button type="button" class="search-segment" data-panel-toggle="who">
          <strong>Who</strong>
          <span class="segment-value" id="who-value">Add guests</span>
        </button>
        <div class="search-dropdown who-dropdown" id="who-panel">
          <div class="guest-row">
            <div class="guest-info"><strong>Adults</strong><span>Ages 13 or above</span></div>
            <div class="guest-counter">
              <button class="counter-btn" data-guest="adults" data-action="dec"><i class="fa-solid fa-minus"></i></button>
              <span class="counter-val" id="count-adults">0</span>
              <button class="counter-btn" data-guest="adults" data-action="inc"><i class="fa-solid fa-plus"></i></button>
            </div>
          </div>
          <div class="guest-row">
            <div class="guest-info"><strong>Children</strong><span>Ages 2–12</span></div>
            <div class="guest-counter">
              <button class="counter-btn" data-guest="children" data-action="dec"><i class="fa-solid fa-minus"></i></button>
              <span class="counter-val" id="count-children">0</span>
              <button class="counter-btn" data-guest="children" data-action="inc"><i class="fa-solid fa-plus"></i></button>
            </div>
          </div>
          <div class="guest-row">
            <div class="guest-info"><strong>Infants</strong><span>Under 2</span></div>
            <div class="guest-counter">
              <button class="counter-btn" data-guest="infants" data-action="dec"><i class="fa-solid fa-minus"></i></button>
              <span class="counter-val" id="count-infants">0</span>
              <button class="counter-btn" data-guest="infants" data-action="inc"><i class="fa-solid fa-plus"></i></button>
            </div>
          </div>
        </div>
      </div>

      <button type="button" class="search-go" aria-label="Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </div>
  </div>
</header>
<div class="navbar-scroll-sentinel" aria-hidden="true"></div>